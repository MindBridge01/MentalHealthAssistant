FRONTEND_PORT=80
BACKEND_PORT=3000
CLIENT_ORIGIN=http://localhost

# Leave blank for local Docker PostgreSQL.
# For a remote database, set the full connection string here.
DATABASE_URL=

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mindbridge
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
POSTGRES_CA_CERT=
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000

JWT_SECRET=replace-with-32-plus-char-secret
PHI_ENCRYPTION_KEY=replace-with-64-hex-or-32-byte-base64-key

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
# If Ollama is installed on your computer instead of Docker, use:
# OLLAMA_BASE_URL=http://host.docker.internal:11434

EMAIL_USER=
EMAIL_PASS=
GOOGLE_CLIENT_ID=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
